{
  "name": "once-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "server:dev": "npm run dev -w apps/once-server",
    "server:build": "npm run build -w apps/once-server",
    "mobile:start": "npm run start -w apps/once-mobile",
    "mobile:android": "npm run android -w apps/once-mobile",
    "mobile:ios": "npm run ios -w apps/once-mobile"
  },
  "devDependencies": {
    "expo": "~54.0.33",
    "expo-router": "~6.0.23"
  }
}
